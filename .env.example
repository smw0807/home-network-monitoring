# ─── 공유기 / SNMP ──────────────────────────────
ROUTER_IP=192.168.0.1
SNMP_COMMUNITY=public
SNMP_IF_INDEX=2          # snmpwalk로 확인한 WAN 인터페이스 인덱스
POLL_INTERVAL_MS=2000

# ─── Elasticsearch ──────────────────────────────
# Docker Compose 배포: http://elasticsearch:9200  (인증 불필요, security 비활성)
# 외부 ES 클러스터 사용 시: https://HOST:9200 + 아래 인증 정보 입력
ES_NODE=http://elasticsearch:9200
ES_USERNAME=
ES_PASSWORD=

# ─── 백엔드 서버 ────────────────────────────────
PORT=4000

# ─── 프론트엔드 (Nuxt 런타임 설정) ─────────────
# Docker 배포 시 비워두면 nginx 프록시 경유 (상대경로 자동 사용)
# 로컬 개발 시: http://localhost:4000
NUXT_PUBLIC_API_URL=
NUXT_PUBLIC_WS_URL=
