# ipTIME Router settings
ROUTER_IP=192.168.0.1
SNMP_COMMUNITY=public
SNMP_IF_INDEX=2
POLL_INTERVAL_MS=2000

# Elasticsearch
ES_NODE=https://elasticsearch:9200
ES_USERNAME=elastic
ES_PASSWORD=your_password_here

# Backend server
PORT=4000

# Frontend (Nuxt runtime config)
NUXT_PUBLIC_API_URL=http://localhost:4000
NUXT_PUBLIC_WS_URL=ws://localhost:4000
